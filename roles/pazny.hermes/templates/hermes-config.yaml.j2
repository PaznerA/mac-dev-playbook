# =============================================================================
# Hermes Agent — configuration
# Generated by Ansible. Edit in roles/pazny.hermes/templates/hermes-config.yaml.j2
# =============================================================================

# ── Primary model: Hermes 4 14B via local Ollama ────────────────────────────
model:
  provider: "openai_compat"                    # Ollama mluvi OpenAI-compat /v1
  base_url: "{{ hermes_ollama_host }}/v1"
  api_key: "ollama-local"
  model: "{{ hermes_primary_model_shortname }}"
  temperature: {{ hermes_temperature | default(0.6) }}
  top_p: {{ hermes_top_p | default(0.95) }}
  top_k: {{ hermes_top_k | default(20) }}

# ── Delegate models (Hermes routes heavy tasks here) ────────────────────────
delegates:
  heavy_local:
    provider: "openai_compat"
    base_url: "{{ hermes_ollama_host }}/v1"
    api_key: "ollama-local"
    model: "{{ hermes_heavy_model }}"
    use_case: "heavy coding tasks, long refactors, complex reasoning"

{% if hermes_anthropic_api_key | length > 0 %}
  anthropic_api:
    provider: "anthropic"
    api_key: "{{ hermes_anthropic_api_key }}"
    model: "claude-opus-4-7-20251009"
    use_case: "fast API-based tasks, Claude-specific features (caching, thinking)"
{% endif %}

{% if hermes_claude_code_enabled | default(true) %}
  claude_code:
    provider: "shell"
    command: "claude"
    args: ["--print", "--dangerously-skip-permissions"]
    timeout: 600
    use_case: "user's Claude Code subscription, no API cost, agentic workflows"
{% endif %}

# ── MCP servers (direct stdio/sse, not via mcpo OpenAPI proxy) ───────────────
mcp_servers:
{% for srv in hermes_mcp_servers %}
  - name: "{{ srv.name }}"
    command: "{{ srv.command }}"
    args: {{ srv.args | tojson }}
{% if srv.env is defined %}
    env:
{% for k, v in srv.env.items() %}
      {{ k }}: "{{ v }}"
{% endfor %}
{% endif %}
{% endfor %}

# ── Execution backends ──────────────────────────────────────────────────────
execution:
  default: "local"                            # local | docker | ssh | daytona | modal
  local:
    workspace: "{{ hermes_home }}/workspace"
    shell: "/bin/zsh"

# ── Memory + skills ──────────────────────────────────────────────────────────
memory:
  backend: "sqlite"
  path: "{{ hermes_config_dir }}/memory.db"
  fts5_enabled: true
  cross_session: true

skills:
  autogen: true                               # auto-ucit skills z dokoncenych tasku
  self_edit: true                             # upravovat existujici skills behem pouziti
  storage: "{{ hermes_config_dir }}/skills"

# ── Concurrency ──────────────────────────────────────────────────────────────
concurrency:
  max_subagents: {{ hermes_max_concurrent_subagents | default(4) }}
  max_parallel_tool_calls: {{ hermes_max_parallel_tool_calls | default(10) }}

# ── Web API (volitelne, pro nginx vhost) ─────────────────────────────────────
{% if hermes_web_enabled | default(true) %}
web:
  enabled: true
  host: "{{ hermes_web_host | default('127.0.0.1') }}"
  port: {{ hermes_web_port | default(18790) }}
  cors_origins:
    - "https://{{ hermes_domain }}"
{% endif %}

# ── Logging ──────────────────────────────────────────────────────────────────
logging:
  level: "INFO"
  file: "{{ hermes_log_dir }}/hermes.log"
  max_size_mb: 50
  rotate_count: 5
