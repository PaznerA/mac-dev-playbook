# =============================================================================
# Hermes Agent — environment variables
# Ansible-managed. Edit roles/pazny.hermes/templates/hermes.env.j2
# Loaded at startup from ~/.hermes/.env
# =============================================================================

# ── Ollama local (already set by com.ollama.agent plist, but belt+suspenders) ──
OLLAMA_HOST={{ hermes_ollama_host }}
OLLAMA_API_KEY=ollama-local

# ── Provider selection (defaults to "custom"/ollama from cli-config.yaml) ──
# HERMES_INFERENCE_PROVIDER=custom

# ── Anthropic Claude API (optional, activated when key set in credentials.yml)
{% if hermes_anthropic_api_key | length > 0 %}
ANTHROPIC_API_KEY={{ hermes_anthropic_api_key }}
{% else %}
# ANTHROPIC_API_KEY=
{% endif %}

# ── Web API (FastAPI) ─────────────────────────────────────────────────────
HERMES_WEB_HOST={{ hermes_web_host | default('127.0.0.1') }}
HERMES_WEB_PORT={{ hermes_web_port | default(18790) }}

# ── Terminal sudo password (optional, for privileged shell cmds) ──────────
# SECURITY: skip in production — use passwordless sudo NOPASSWD: lines instead
# TERMINAL_SUDO_PASSWORD=""

# ── Skip telemetry ──────────────────────────────────────────────────────────
ANONYMIZED_TELEMETRY=false
DO_NOT_TRACK=true
