{# ── Panel 3: Jazyky ────────────────────────────────────────────────────── #}
{% set _lang_items = [] %}
{% if install_php | default(true) %}
{% set _subs = [] %}
{% for ext in php_extensions | default([]) %}
{% set _ = _subs.append("<li style='" ~ S_sub ~ "'>&#10003; " ~ ext.split('-')[-1] ~ "</li>") %}
{% endfor %}
{% set _ = _lang_items.append("<li style='margin-bottom:12px'><span style='" ~ S_dot ~ "'></span><span style='" ~ S_name ~ "'>PHP</span><span style='" ~ S_ver ~ "'>" ~ (php_version | default('8.3')) ~ "</span><ul style='list-style:none;padding-left:20px;margin-top:4px'>" ~ _subs | join('') ~ "</ul></li>") %}
{% endif %}
{% if install_node | default(true) %}
{% set _subs = [] %}
{% for pkg in node_global_packages | default([]) %}
{% set _ = _subs.append("<li style='" ~ S_sub ~ "'>&#10003; " ~ pkg ~ "</li>") %}
{% endfor %}
{% set _ = _lang_items.append("<li style='margin-bottom:12px'><span style='" ~ S_dot ~ "'></span><span style='" ~ S_name ~ "'>Node.js</span><span style='" ~ S_ver ~ "'>" ~ (node_nvm_version | default('lts/*')) ~ "</span><ul style='list-style:none;padding-left:20px;margin-top:4px'>" ~ _subs | join('') ~ "</ul></li>") %}
{% endif %}
{% if install_bun | default(true) %}
{% set _ = _lang_items.append("<li style='margin-bottom:12px'><span style='" ~ S_dot ~ "'></span><span style='" ~ S_name ~ "'>Bun</span><span style='" ~ S_ver ~ "'>latest</span></li>") %}
{% endif %}
{% if install_python | default(true) %}
{% set _subs = [] %}
{% for pkg in pip_packages | default([]) %}
{% set _ = _subs.append("<li style='" ~ S_sub ~ "'>&#10003; " ~ pkg.name ~ "</li>") %}
{% endfor %}
{% set _ = _lang_items.append("<li style='margin-bottom:12px'><span style='" ~ S_dot ~ "'></span><span style='" ~ S_name ~ "'>Python</span><span style='" ~ S_ver ~ "'>" ~ (python_version | default('3.13')) ~ "</span><ul style='list-style:none;padding-left:20px;margin-top:4px'>" ~ _subs | join('') ~ "</ul></li>") %}
{% endif %}
{% if install_golang | default(true) %}
{% set _subs = [] %}
{% for pkg in go_packages | default([]) %}
{% set _ = _subs.append("<li style='" ~ S_sub ~ "'>&#10003; " ~ pkg.split('/')[-1].split('@')[0] ~ "</li>") %}
{% endfor %}
{% set _ = _lang_items.append("<li style='margin-bottom:12px'><span style='" ~ S_dot ~ "'></span><span style='" ~ S_name ~ "'>Go</span><span style='" ~ S_ver ~ "'>latest</span><ul style='list-style:none;padding-left:20px;margin-top:4px'>" ~ _subs | join('') ~ "</ul></li>") %}
{% endif %}
{% if install_dotnet | default(true) %}
{% set _subs = [] %}
{% for tool in dotnet_global_tools | default([]) %}
{% set _ = _subs.append("<li style='" ~ S_sub ~ "'>&#10003; " ~ tool.name ~ "</li>") %}
{% endfor %}
{% set _ = _lang_items.append("<li style='margin-bottom:12px'><span style='" ~ S_dot ~ "'></span><span style='" ~ S_name ~ "'>.NET</span><span style='" ~ S_ver ~ "'>latest</span><ul style='list-style:none;padding-left:20px;margin-top:4px'>" ~ _subs | join('') ~ "</ul></li>") %}
{% endif %}
{# ── Panel 4: Homebrew balíčky ───────────────────────────────────────────── #}
{% set _brew_cli = [] %}
{% for pkg in homebrew_installed_packages | default([]) %}
{% set _ = _brew_cli.append("<span style='" ~ S_pkg ~ "'>" ~ pkg ~ "</span>") %}
{% endfor %}
{% set _brew_cask = [] %}
{% for app in homebrew_cask_apps | default([]) %}
{% set _ = _brew_cask.append("<span style='" ~ S_pkg ~ "'>" ~ app ~ "</span>") %}
{% endfor %}
