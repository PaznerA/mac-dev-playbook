{% set _ = _cards.append("<div style='" ~ S_card ~ "'><span style='" ~ S_dot ~ "'></span><a href='https://" ~ (woodpecker_domain | default('ci.dev.local')) ~ "' target='_blank' style='" ~ S_link ~ "'>Woodpecker CI</a><div style='" ~ S_desc ~ "'>CI/CD pipeline</div><div style='" ~ S_meta ~ "'>:" ~ (woodpecker_port | default(8060)) ~ " <span style='" ~ S_badge ~ "'>devops</span></div></div>") %}
