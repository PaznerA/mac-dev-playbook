{% endif %}
{# ── Panel 2: Tier 2 řádky tabulky ──────────────────────────────────────── #}
{% set _rows = [] %}
{% macro trow(name, ports, ttype, tstyle, stack, desc) %}
{% set _ = _rows.append("<tr><td style='" ~ S_td ~ "'><span style='" ~ S_dot ~ "'></span>" ~ name ~ "</td><td style='" ~ S_td ~ ";" ~ S_port ~ "'>" ~ ports ~ "</td><td style='" ~ S_td ~ ";" ~ tstyle ~ "'>" ~ ttype ~ "</td><td style='" ~ S_td ~ "'>" ~ stack ~ "</td><td style='" ~ S_td ~ "'>" ~ desc ~ "</td></tr>") %}
{% endmacro %}
{% if install_nginx | default(true) %}
{{ trow("Nginx", "80, 443", "homebrew", S_brew, "host", "Reverse proxy + SSL") }}
{{ trow("PHP-FPM", "socket", "homebrew", S_brew, "host", "PHP FastCGI") }}
{% endif %}
{% if install_dnsmasq | default(true) %}
{{ trow("dnsmasq", dnsmasq_port | default(53) | string, "homebrew", S_brew, "host", "DNS resolver (*.dev.local)") }}
{% endif %}
{% if install_mariadb | default(false) %}
{{ trow("MariaDB", mariadb_port | default(3306) | string, "docker", S_docker, "iiab", "Relacni databaze") }}
{% endif %}
{% if install_php | default(true) %}
{{ trow("Redis", redis_port | default(6379) | string, "homebrew", S_brew, "host", "In-memory cache") }}
{% endif %}
{% if install_observability | default(true) %}
{{ trow("Prometheus", prometheus_port | default(9090) | string, "docker", S_docker, "observability", "Metriky a alerting") }}
{{ trow("Loki", loki_port | default(3100) | string, "docker", S_docker, "observability", "Agregace logu") }}
{{ trow("Tempo", (tempo_http_port | default(3200) | string) ~ ", " ~ (tempo_otlp_grpc_port | default(4327) | string) ~ ", " ~ (tempo_otlp_http_port | default(4328) | string), "docker", S_docker, "observability", "Distribuovany tracing") }}
{{ trow("Alloy", (alloy_ui_port | default(12345) | string) ~ ", " ~ (alloy_otlp_grpc_port | default(4317) | string) ~ ", " ~ (alloy_otlp_http_port | default(4318) | string), "homebrew", S_brew, "host", "Kolektor metrik a logu") }}
{{ trow("node_exporter", "9100", "homebrew", S_brew, "host", "Systemove metriky macOS") }}
{{ trow("nginx-exporter", "9113", "binary", S_bin, "host", "Nginx metriky") }}
{{ trow("php-fpm_exporter", phpfpm_exporter_port | default(9253) | string, "binary", S_bin, "host", "PHP-FPM metriky") }}
{% endif %}
{% if install_openclaw | default(true) %}
{{ trow("Ollama", "11434", "homebrew", S_brew, "host", "LLM inference engine") }}
{% endif %}
{% if install_uptime_kuma | default(false) %}
{{ trow("Uptime Kuma", uptime_kuma_port | default(3001) | string, "docker", S_docker, "iiab", "Monitoring dostupnosti") }}
