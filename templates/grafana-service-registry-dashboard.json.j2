{% if install_gitea | default(false) %}
{% set _ = _cards.append("<div style='" ~ S_card ~ "'><span style='" ~ S_dot ~ "'></span><a href='https://" ~ (gitea_domain | default('git.dev.local')) ~ "' target='_blank' style='" ~ S_link ~ "'>Gitea</a><div style='" ~ S_desc ~ "'>Self-hosted Git</div><div style='" ~ S_meta ~ "'>:" ~ (gitea_port | default(3003)) ~ " <span style='" ~ S_badge ~ "'>devops</span></div></div>") %}
