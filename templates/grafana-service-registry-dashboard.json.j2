        "mode": "html",
        "content": {{ ("<div style='text-align:center;font-size:11px;color:rgba(230,237,243,0.3)'>Generovano " ~ ansible_date_time.iso8601 ~ " | ansible-playbook main.yml --tags service-registry</div>") | to_json }}
      }
    }
  ]
