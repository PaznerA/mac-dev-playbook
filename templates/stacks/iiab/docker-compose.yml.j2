# =============================================================================
# IIAB STACK – self-hosted knowledge & media services
# Generováno Ansiblem – NEUPRAVUJ ručně
# =============================================================================

services:

{# MariaDB přesunuta do infra stacku – služby se připojují přes shared_net #}
{% if install_wordpress | default(false) %}
  wordpress:
    image: wordpress:{{ wordpress_version | default('latest') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ wordpress_port | default(8084) }}:80"
    volumes:
      - {{ wordpress_dir }}:/var/www/html
    environment:
      WORDPRESS_DB_HOST: "{% if install_mariadb | default(false) %}mariadb{% else %}{{ wordpress_db_host | default('127.0.0.1') }}{% endif %}"
      WORDPRESS_DB_USER: "{{ wordpress_db_user }}"
      WORDPRESS_DB_PASSWORD: "{{ wordpress_db_password }}"
      WORDPRESS_DB_NAME: "{{ wordpress_db_name }}"
      WORDPRESS_TABLE_PREFIX: "{{ wordpress_table_prefix | default('wp_') }}"
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ wordpress_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{% if install_nextcloud | default(false) %}
  nextcloud:
    image: nextcloud:{{ nextcloud_version | default('stable') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ nextcloud_port | default(8085) }}:80"
{% else %}
      - "127.0.0.1:{{ nextcloud_port | default(8085) }}:80"
{% endif %}
    volumes:
      - {{ nextcloud_dir }}:/var/www/html
      - {{ nextcloud_data_dir }}:/data
    environment:
      MYSQL_HOST: "{% if install_mariadb | default(false) %}mariadb{% else %}{{ nextcloud_db_host | default('127.0.0.1') }}{% endif %}"
      MYSQL_DATABASE: "{{ nextcloud_db_name }}"
      MYSQL_USER: "{{ nextcloud_db_user }}"
      MYSQL_PASSWORD: "{{ nextcloud_db_password }}"
      NEXTCLOUD_ADMIN_USER: "{{ nextcloud_admin_user }}"
      NEXTCLOUD_ADMIN_PASSWORD: "{{ nextcloud_admin_password }}"
      NEXTCLOUD_DATA_DIR: "/data"
      NEXTCLOUD_TRUSTED_DOMAINS: "{{ nextcloud_domain | default('cloud.dev.local') }} localhost 127.0.0.1"
      OVERWRITEPROTOCOL: "https"
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ nextcloud_mem_limit | default(docker_mem_limit_critical) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{% if install_n8n | default(false) %}
  n8n:
    image: n8nio/n8n:{{ n8n_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ n8n_port | default(5678) }}:5678"
{% else %}
      - "127.0.0.1:{{ n8n_port | default(5678) }}:5678"
{% endif %}
    volumes:
      - {{ n8n_data_dir }}:/home/node/.n8n
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/usr/local/share/ca-certificates/mkcert-ca.crt:ro
    environment:
      N8N_HOST: "{{ n8n_domain | default('n8n.dev.local') }}"
      N8N_PORT: "5678"
      N8N_PROTOCOL: https
      WEBHOOK_URL: "https://{{ n8n_domain | default('n8n.dev.local') }}/"
      GENERIC_TIMEZONE: "{{ n8n_timezone | default('Europe/Prague') }}"
      TZ: "{{ n8n_timezone | default('Europe/Prague') }}"
      NODE_EXTRA_CA_CERTS: "/usr/local/share/ca-certificates/mkcert-ca.crt"
{% if install_authentik | default(false) %}
      # ── Authentik SSO (OIDC) ───────────────────────────────────────────────
      N8N_AUTH_OIDC_ENABLED: "true"
      N8N_AUTH_OIDC_CLIENT_ID: "{{ (authentik_oidc_apps | selectattr('slug', 'equalto', 'n8n') | first).client_id }}"
      N8N_AUTH_OIDC_CLIENT_SECRET: "{{ (authentik_oidc_apps | selectattr('slug', 'equalto', 'n8n') | first).client_secret }}"
      N8N_AUTH_OIDC_ISSUER: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/n8n/"
      N8N_AUTH_OIDC_ALLOWED_GROUPS: ""
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:5678/healthz || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
{% if install_authentik | default(false) %}
    extra_hosts:
      - "{{ authentik_domain | default('auth.dev.local') }}:host-gateway"
{% endif %}
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ n8n_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{% if install_kiwix | default(false) %}
  kiwix:
    image: ghcr.io/kiwix/kiwix-serve:{{ kiwix_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ kiwix_port | default(8888) }}:8080"
{% else %}
      - "127.0.0.1:{{ kiwix_port | default(8888) }}:8080"
{% endif %}
    volumes:
      - {{ kiwix_data_dir }}:/data
    command: /data/*.zim
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ kiwix_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ docker_cpus_light | default('0.5') }}

{% endif %}
{% if install_jellyfin | default(false) %}
  jellyfin:
    image: jellyfin/jellyfin:{{ jellyfin_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if jellyfin_lan_access | default(false) or services_lan_access | default(false) %}
      - "{{ jellyfin_port | default(8096) }}:8096"
{% else %}
      - "127.0.0.1:{{ jellyfin_port | default(8096) }}:8096"
{% endif %}
    volumes:
      - {{ jellyfin_config_dir }}:/config
      - {{ jellyfin_cache_dir }}:/cache
      - {{ jellyfin_movies_dir }}:/media/movies:ro
      - {{ jellyfin_shows_dir }}:/media/shows:ro
      - {{ jellyfin_music_dir }}:/media/music:ro
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ jellyfin_mem_limit | default(docker_mem_limit_critical) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{# uptime-kuma service byl extrahovany do role pazny.uptime_kuma (Wave 2.2)
   a rendereruje se do {{ stacks_dir }}/iiab/overrides/uptime-kuma.yml.
   Stack-up.yml ho sesbira pres `find` a prida jako dodatecny -f flag. #}
{% if install_calibreweb | default(false) %}
  calibre-web:
    image: lscr.io/linuxserver/calibre-web:{{ calibreweb_version | default('latest') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ calibreweb_port | default(8083) }}:8083"
    volumes:
      - {{ ansible_facts['env']['HOME'] }}/calibre-web/config:/config
      - {{ calibreweb_books_dir }}:/books
    environment:
      PUID: "{{ ansible_facts['user_uid'] }}"
      PGID: "{{ ansible_facts['user_gid'] }}"
      TZ: "{{ calibreweb_timezone | default('Europe/Prague') }}"
      DOCKER_MODS: linuxserver/mods:universal-calibre
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ calibreweb_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ docker_cpus_light | default('0.5') }}

{% endif %}
{# open-webui service byl extrahovany do role pazny.open_webui (Wave 2.2)
   a rendereruje se do {{ stacks_dir }}/iiab/overrides/open-webui.yml.
   Stack-up.yml ho sesbira pres `find` a prida jako dodatecny -f flag. #}
{% if install_homeassistant | default(false) %}
  homeassistant:
    image: homeassistant/home-assistant:{{ homeassistant_version | default('stable') }}
    restart: unless-stopped
{% if homeassistant_privileged | default(false) %}
    privileged: true
    network_mode: host
{% else %}
    ports:
      - "127.0.0.1:{{ homeassistant_port | default(8123) }}:8123"
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
{% endif %}
    volumes:
      - {{ homeassistant_config_dir | default(ansible_facts['env']['HOME'] + '/homeassistant') }}:/config
    tmpfs:
      - /tmp
    environment:
      TZ: "{{ homeassistant_timezone | default('Europe/Prague') }}"
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ homeassistant_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{# rustfs service byl extrahovany do role pazny.rustfs (Wave 2.2) a
   rendereruje se do {{ stacks_dir }}/iiab/overrides/rustfs.yml.
   Stack-up.yml ho sesbira pres `find` a prida jako dodatecny -f flag. #}
{% if install_offline_maps | default(false) %}
  tileserver:
    image: maptiler/tileserver-gl:{{ maps_tileserver_version | default('latest') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ maps_port | default(8070) }}:8080"
    volumes:
      - {{ maps_data_dir }}:/data
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ tileserver_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ docker_cpus_light | default('0.5') }}

{% endif %}
{% if install_puter | default(false) %}
  # ── Puter – cloud OS webový desktop ───────────────────────────────────────
  puter:
    build:
      context: {{ playbook_dir }}/files/puter
      dockerfile: Dockerfile
    image: devboxnos/puter:{{ puter_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ puter_port | default(5050) }}:4100"
{% else %}
      - "127.0.0.1:{{ puter_port | default(5050) }}:4100"
{% endif %}
    environment:
      PUID: "{{ ansible_facts['user_uid'] }}"
      PGID: "{{ ansible_facts['user_gid'] }}"
      TZ: "Europe/Prague"
    volumes:
      - {{ puter_config_dir | default(ansible_facts['env']['HOME'] + '/puter/config') }}:/etc/puter
      - {{ puter_data_dir | default(ansible_facts['env']['HOME'] + '/puter') }}/data:/var/puter
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider --header='Host: {{ puter_domain | default('os.dev.local') }}' http://127.0.0.1:4100/ || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 60s
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ puter_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{# vaultwarden service byl extrahovany do role pazny.vaultwarden (Wave 2.2)
   a rendereruje se do {{ stacks_dir }}/iiab/overrides/vaultwarden.yml.
   Stack-up.yml ho sesbira pres `find` a prida jako dodatecny -f flag. #}

networks:
  iiab_net:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16
  {{ stacks_shared_network }}:
    external: true
